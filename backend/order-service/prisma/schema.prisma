// ==========================================
// Prisma Schema - Order Service (order_db)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id @default(uuid())
  orderCode       String   @default("")
  customerId      String
  items           Json     // OrderItem[]
  totalAmount     Float
  shippingAddress Json     // ShippingAddress
  status          String   @default("PENDING")
  paymentMethod   String   @default("SEPAY_QR")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("orders")
}

model Event {
  id            Int      @id @default(autoincrement())
  eventId       String
  type          String
  source        String
  correlationId String
  payload       Json
  timestamp     DateTime
  storedAt      DateTime @default(now())

  @@index([correlationId])
  @@index([type])
  @@map("events")
}

// ==========================================
// Prisma Schema - Inventory Service (inventory_db)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InventoryItem {
  productId         String   @id
  productName       String
  totalStock        Int
  reservedStock     Int      @default(0)
  availableStock    Int
  lowStockThreshold Int      @default(10)
  updatedAt         DateTime @updatedAt

  price             Float?   @default(150000)
  category          String?  @default("Linh kiện")
  shortDescription  String?  @default("Mô tả ngắn sản phẩm.")
  description       String?  @default("Mô tả chi tiết sản phẩm.")
  specs             Json?    @default("[]")
  accentClass       String?  @default("from-slate-800 to-slate-500")
  rating            Float?   @default(4.5)
  sold              Int?     @default(10)
  warranty          String?  @default("12 tháng chính hãng")
  image             String?

  @@map("inventory_items")
}

model StockReservation {
  id        String   @id @default(uuid())
  orderId   String
  items     Json     // Array<{ productId, quantity }>
  status    String   @default("RESERVED")
  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("stock_reservations")
}

model Event {
  id            Int      @id @default(autoincrement())
  eventId       String
  type          String
  source        String
  correlationId String
  payload       Json
  timestamp     DateTime
  storedAt      DateTime @default(now())

  @@index([correlationId])
  @@index([type])
  @@map("events")
}

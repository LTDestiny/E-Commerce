{
  "name": "@ecommerce/inventory-service",
  "version": "1.0.0",
  "description": "Inventory Service - Manages stock and reservations",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "dev": "npx prisma generate && ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push"
  },
  "dependencies": {
    "@ecommerce/shared": "file:../shared",
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}

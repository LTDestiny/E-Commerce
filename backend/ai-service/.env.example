# ==========================================
# AI Service - Environment Configurations
# ==========================================
# Copy file này thành .env và điền giá trị thực vào trước khi chạy

PORT=4007
REDIS_URL=redis://redis:6379
CORS_ORIGIN=http://localhost:3000

# Endpoint to fetch real-time product list (Inventory Service)
INVENTORY_SERVICE_URL=http://inventory-service:4003

# Google Gemini API Key (Obtain from Google AI Studio: https://aistudio.google.com/)
# Tạo project mới và tạo API Key mới (Free tier) tại link trên
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

// ==========================================
// Prisma Schema - Notification Service (notification_db)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id         String    @id @default(uuid())
  orderId    String
  customerId String
  type       String
  subject    String
  body       String
  status     String    @default("PENDING")
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([orderId])
  @@map("notifications")
}

model Event {
  id            Int      @id @default(autoincrement())
  eventId       String
  type          String
  source        String
  correlationId String
  payload       Json
  timestamp     DateTime
  storedAt      DateTime @default(now())

  @@index([correlationId])
  @@index([type])
  @@map("events")
}

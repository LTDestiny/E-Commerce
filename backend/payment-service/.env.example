# ==========================================
# Payment Service - Environment Configurations
# ==========================================
PORT=4002
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:admin@localhost:5432/payment_db
PAYMENT_METHOD=SEPAY_QR
SEPAY_PROVIDER_NAME=SePay
SEPAY_PAYMENT_ACCOUNT=880123456789
SEPAY_BANK_NAME=VietQR Demo Bank
SEPAY_QR_TEMPLATE=SEPAY-{orderId}-{amount}
SEPAY_WEBHOOK_SECRET=dev_sepay_webhook_secret
SEPAY_WEBHOOK_PATH=/api/payments/sepay/webhook
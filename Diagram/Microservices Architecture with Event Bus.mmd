---
config:
  layout: elk
---
graph TB
    subgraph "API Gateway Layer"
        AG[API Gateway]:::gateway
    end
    
    subgraph "Order Service Domain"
        OS[Order Service]:::service
        ODB[(Order DB)]:::db
    end
    
    subgraph "Inventory Service Domain"
        IS[Inventory Service]:::service
        IDB[(Inventory DB)]:::db
    end
    
    subgraph "Payment Service Domain"
        PS[Payment Service]:::service
        PDB[(Payment DB)]:::db
        PGW[Payment Gateway API]:::external
    end
    
    subgraph "Shipping Service Domain"
        SS[Shipping Service]:::service
        SDB[(Shipping DB)]:::db
        SPAPI[Shipping Provider API]:::external
    end
    
    subgraph "Notification Service Domain"
        NS[Notification Service]:::service
        NDB[(Notification Log DB)]:::db
        SMTP[Email/SMS Gateway]:::external
    end
    
    subgraph "Message Broker Infrastructure"
        direction LR
        EB[Event Bus<br/>Kafka/RabbitMQ]:::broker
        ES[Event Store<br/>Event Sourcing]:::eventstore
        DLQ[Dead Letter Queue]:::dlq
    end
    
    subgraph "Monitoring & Observability"
        MON[Monitoring<br/>Prometheus/Grafana]:::monitor
        LOG[Centralized Logging<br/>ELK Stack]:::monitor
        TRACE[Distributed Tracing<br/>Jaeger/Zipkin]:::monitor
    end
    User([User/Client]):::user --> AG
    AG --> OS
    OS <-->|Publish/Subscribe| EB
    IS <-->|Publish/Subscribe| EB
    PS <-->|Publish/Subscribe| EB
    SS <-->|Publish/Subscribe| EB
    NS <-->|Publish/Subscribe| EB
    OS --> ODB
    IS --> IDB
    PS --> PDB
    SS --> SDB
    NS --> NDB
    PS --> PGW
    SS --> SPAPI
    NS --> SMTP
    EB -.->|Store Events| ES
    EB -.->|Failed Events| DLQ
    OS -.->|Metrics/Logs| MON
    IS -.->|Metrics/Logs| MON
    PS -.->|Metrics/Logs| MON
    SS -.->|Metrics/Logs| MON
    NS -.->|Metrics/Logs| MON
    EB -.->|Metrics| MON
    
    OS -.->|Traces| TRACE
    IS -.->|Traces| TRACE
    PS -.->|Traces| TRACE
    
    OS -.->|Logs| LOG
    IS -.->|Logs| LOG
    PS -.->|Logs| LOG
    classDef gateway fill:#00BCD4,stroke:#006064,stroke-width:3px,color:#fff
    classDef service fill:#2196F3,stroke:#0D47A1,stroke-width:2px,color:#fff
    classDef db fill:#4CAF50,stroke:#1B5E20,stroke-width:2px,color:#fff
    classDef broker fill:#FF9800,stroke:#E65100,stroke-width:3px,color:#fff
    classDef eventstore fill:#9C27B0,stroke:#4A148C,stroke-width:2px,color:#fff
    classDef dlq fill:#F44336,stroke:#B71C1C,stroke-width:2px,color:#fff
    classDef external fill:#FF5722,stroke:#BF360C,stroke-width:2px,color:#fff
    classDef monitor fill:#607D8B,stroke:#263238,stroke-width:2px,color:#fff
    classDef user fill:#8BC34A,stroke:#33691E,stroke-width:3px,color:#fff